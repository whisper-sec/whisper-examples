{
  "log": {
    "sanitize": [
      "request.headers.x-api-key",
      "response.body"
    ]
  },
  "url": "https://graph.whisper.security/api/query",
  "body": {
    "query": "CALL whisper.agents({op:'register', args:{label:'{{replace(parameters.label, \"'\", \"''\")}}'{{if(length(parameters.contact_email) > 0, \",contact_email:'\" + replace(parameters.contact_email, \"'\", \"''\") + \"'\", \"\")}}}})"
  },
  "method": "POST",
  "headers": {
    "x-api-key": "{{connection.apiKey}}",
    "content-type": "application/json"
  },
  "response": {
    "error": {
      "message": "[{{statusCode}}] Whisper register failed: {{ifempty(body.detail, ifempty(body.title, 'the Whisper control plane rejected the request - check your API key and its scope'))}}"
    },
    "output": {
      "ok": "{{ifempty(body.ok, get(get(body.rows, 1), 'ok'))}}",
      "ptr": "{{get(get(get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'rows'), 1), 5)}}",
      "fqdn": "{{get(get(get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'rows'), 1), 4)}}",
      "rows": "{{get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'rows')}}",
      "agent": "{{get(get(get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'rows'), 1), 2)}}",
      "address": "{{get(get(get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'rows'), 1), 3)}}",
      "api_key": "{{get(get(get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'rows'), 1), 1)}}",
      "columns": "{{get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'columns')}}"
    }
  }
}
