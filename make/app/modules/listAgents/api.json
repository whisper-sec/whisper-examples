{
  "log": {
    "sanitize": [
      "request.headers.x-api-key"
    ]
  },
  "url": "https://graph.whisper.security/api/query",
  "body": {
    "query": "CALL whisper.agents({op:'list', args:{kind:'{{parameters.kind}}'}})"
  },
  "method": "POST",
  "headers": {
    "x-api-key": "{{connection.apiKey}}",
    "content-type": "application/json"
  },
  "response": {
    "error": {
      "message": "[{{statusCode}}] Whisper list failed: {{ifempty(body.detail, ifempty(body.title, 'the Whisper control plane rejected the request — check your API key and its scope'))}}"
    },
    "output": {
      "ok": "{{ifempty(body.ok, get(get(body.rows, 1), 'ok'))}}",
      "rows": "{{get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'rows')}}",
      "count": "{{length(get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'rows'))}}",
      "columns": "{{get(ifempty(body.result, get(get(body.rows, 1), 'result')), 'columns')}}"
    }
  }
}
